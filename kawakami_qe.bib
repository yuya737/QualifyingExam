	keywords = {Companies, Data visualization, Design methodology, Displays, Geography, geovisualization, Humans, Information visualization, multivariate and spatio-temporal data, ordering, Pattern analysis, self-organizing map (SOM), small multiples., Sorting, Spatiotemporal phenomena, Time varying systems, visual analytics},
	pages = {1461--1474},
	file = {IEEE Xplore Abstract Record:/Users/yuyakawakami/Zotero/storage/Z95PBTKQ/1703367.html:text/html;IEEE Xplore Full Text PDF:/Users/yuyakawakami/Zotero/storage/8MUFDTV3/Guo et al. - 2006 - A Visualization System for Space-Time and Multivar.pdf:application/pdf},
