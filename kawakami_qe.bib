	journal = {IEEE Transactions on Visualization and Computer Graphics},
	author = {Kappe, Christopher P. and Bottinger, Michael and Leitte, Heike},
	month = mar,
	year = {2019},
	pages = {1499--1512},
}

    
@article{kappe_analysis_2019,
	title = {Analysis of {Decadal} {Climate} {Predictions} with {User}-guided {Hierarchical} {Ensemble} {Clustering}},
	volume = {38},
	issn = {1467-8659},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/cgf.13706},
	doi = {10.1111/cgf.13706},
	abstract = {In order to gain probabilistic results, ensemble simulation techniques are increasingly applied in the weather and climate sciences (as well as in various other scientific disciplines). In many cases, however, only mean results or other abstracted quantities such as percentiles are used for further analyses and dissemination of the data. In this work, we aim at a more detailed visualization of the temporal development of the whole ensemble that takes the variability of all single members into account. We propose a visual analytics tool that allows an effective analysis process based on a hierarchical clustering of the time-dependent scalar fields. The system includes a flow chart that shows the ensemble members' cluster affiliation over time, reflecting the whole cluster hierarchy. The latter one can be dynamically explored using a visualization derived from a dendrogram. As an aid in linking the different views, we have developed an adaptive coloring scheme that takes into account cluster similarity and the containment relationships. Finally, standard visualizations of the involved field data (cluster means, ground truth data, etc.) are also incorporated. We include results of our work on real-world datasets to showcase the utility of our approach.},
	language = {en},
	number = {3},
	urldate = {2023-11-08},
	journal = {Computer Graphics Forum},
	author = {Kappe, C.p. and Böttinger, M. and Leitte, H.},
	year = {2019},
	pages = {505--515},
	file = {Full Text PDF:/Users/yuyakawakami/Zotero/storage/NS6S2ZTF/Kappe et al. - 2019 - Analysis of Decadal Climate Predictions with User-.pdf:application/pdf;Snapshot:/Users/yuyakawakami/Zotero/storage/V6SNCZLI/cgf.html:text/html},
}
