	keywords = {evaluation, Glyph visualization, multidimensional spatial data, square-glyphs, user study},
	pages = {449--465},
	file = {Full Text PDF:/Users/yuyakawakami/Zotero/storage/FJN8U9JJ/Müller et al. - 2023 - Square-glyphs assessing the readability of multid.pdf:application/pdf},
}

